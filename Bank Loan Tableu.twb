      <aliases enabled='yes' />
      <column caption='Total Loan Applications' datatype='integer' name='[Calculation_0121839157276672]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT((id))' />
      </column>
      <column caption='MTD Total Loan Application' datatype='integer' name='[Calculation_0121839159545857]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF&#13;&#10;DATEDIFF(&apos;month&apos;,[issue_date],{MAX([issue_date])})=0&#13;&#10;THEN&#13;&#10;[id]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='MOM Loan Applications' datatype='real' name='[Calculation_0121839163580423]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_0121839159545857]-[MTD Total Loan Application (copy)_0121839162933253])&#13;&#10;/&#13;&#10;[MTD Total Loan Application (copy)_0121839162933253]' />
      </column>
      <column caption='Total Funded Amount' datatype='integer' name='[Calculation_0121839164604424]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([loan_amount])' />
      </column>
      <column caption='MOM Total Funded' datatype='real' name='[Calculation_0121839166390283]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([MTD Total Loan Application (copy)_0121839165427721]-[PMTD Loan Application (copy) (copy)_0121839166136330])&#13;&#10;/&#13;&#10;[PMTD Loan Application (copy) (copy)_0121839166136330]' />
      </column>
      <column caption='Total Amount Recieved' datatype='integer' name='[Calculation_0121839168311308]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_payment])' />
      </column>
      <column caption='MOM recieved' datatype='real' name='[Calculation_0121839169527823]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([MTD Total Funded Amount (copy)_0121839168831501]-[MTD Total Recieved Amount (copy)_0121839169302542])&#13;&#10;/&#13;&#10;[MTD Total Recieved Amount (copy)_0121839169302542]' />
      </column>
      <column caption='Avg Int Rate' datatype='real' name='[Calculation_0301334776938496]' role='measure' type='quantitative'>
